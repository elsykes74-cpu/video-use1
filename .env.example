# ElevenLabs — required for video transcription
ELEVENLABS_API_KEY=

# Telegram bot — required for bot/bot.py
TELEGRAM_BOT_TOKEN=

# YouTube Data API v3 — optional, enables /status command in the bot
# Get a free key at console.cloud.google.com (enable "YouTube Data API v3")
# Find your channel ID at youtube.com/account_advanced
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
