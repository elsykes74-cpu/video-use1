# ElevenLabs — required for video transcription and premium voiceover
ELEVENLABS_API_KEY=

# Telegram bot — required for bot/bot.py
TELEGRAM_BOT_TOKEN=

# Google Gemini — required for /generate (AI visuals + thumbnails)
# Free key at: https://aistudio.google.com/apikey  (use AI Studio, NOT Vertex)
GEMINI_API_KEY=

# YouTube Data API v3 — enables /status command in the bot
# Free key at console.cloud.google.com (enable "YouTube Data API v3")
# Find your channel ID at youtube.com/account_advanced
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
